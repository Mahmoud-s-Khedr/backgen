{
  "name": "backend-creator",
  "version": "1.0.0",
  "description": "Generate a complete, production-ready Express.js REST API backend from a Prisma schema file",
  "type": "module",
  "main": "./dist/generator/cli.js",
  "bin": {
    "bcm": "./dist/generator/cli.js"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node18 --outfile=dist/generator/cli.js --format=esm --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" && rm -rf dist/templates && cp -r src/templates dist/templates && cp package.json dist/package.json",
    "dev": "npm run build && node dist/generator/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prisma",
    "express",
    "rest-api",
    "code-generator",
    "cli",
    "backend",
    "scaffold",
    "crud"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@mrleebo/prisma-ast": "^0.14.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ejs": "^4.0.1",
    "fs-extra": "^11.3.3",
    "ora": "^9.3.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@types/pluralize": "^0.0.33",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
