{
  "name": "prisma-backgen",
  "version": "1.0.5",
  "description": "Generate a complete, production-ready Express.js REST API backend from a Prisma schema file",
  "type": "module",
  "main": "./dist/generator/cli.js",
  "bin": {
    "bcm": "./dist/generator/cli.js",
    "prisma-backgen": "./dist/generator/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run build && node dist/generator/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "examples": "node scripts/run-examples.js",
    "prepublishOnly": "npm run build",
    "portfolio:shots": "node scripts/capture-playground-screenshots.mjs && node scripts/capture-cli-proof.mjs",
    "portfolio:screenshots": "node scripts/capture-playground-screenshots.mjs",
    "portfolio:cli-proof": "node scripts/capture-cli-proof.mjs"
  },
  "keywords": [
    "prisma",
    "express",
    "rest-api",
    "code-generator",
    "cli",
    "backend",
    "scaffold",
    "crud"
  ],
  "author": "Mahmoud Khedr",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@mrleebo/prisma-ast": "^0.14.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ejs": "^4.0.1",
    "fs-extra": "^11.3.3",
    "ora": "^9.3.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@types/pluralize": "^0.0.33",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mahmoud-s-Khedr/backgen.git"
  },
  "homepage": "https://github.com/Mahmoud-s-Khedr/backgen",
  "bugs": {
    "url": "https://github.com/Mahmoud-s-Khedr/backgen/issues"
  }
}
