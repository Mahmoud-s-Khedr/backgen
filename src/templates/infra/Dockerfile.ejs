# ---- Build Stage ----
FROM node:22-alpine AS builder
RUN apk add --no-cache openssl<%= provider === 'sqlite' ? ' python3 make g++' : '' %>
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY package.json pnpm-lock.yaml ./
COPY prisma ./prisma/
RUN <%= provider === 'sqlite' ? 'npm_config_build_from_source=true ' : '' %>pnpm install --frozen-lockfile
# .dockerignore keeps host artifacts like node_modules and dist out of this copy.
COPY . .
RUN npx prisma generate
RUN pnpm run build
RUN test -f openapi.json || echo '{}' > openapi.json

# ---- Production Stage ----
FROM node:22-alpine AS runner
RUN apk add --no-cache openssl<%= provider === 'sqlite' ? ' libstdc++ libgcc' : '' %>
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 appuser

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/openapi.json ./openapi.json
COPY --from=builder /app/prisma.config.ts ./
COPY --from=builder /app/docker-entrypoint.sh ./docker-entrypoint.sh

RUN chmod +x /app/docker-entrypoint.sh

# <% if (provider === 'sqlite') { %>
RUN mkdir -p /app/data && chown appuser:nodejs /app/data
# <% } %>
# <% if (hasUploads) { %>
RUN mkdir -p /app/uploads && chown -R appuser:nodejs /app/uploads
# <% } %>
USER appuser
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://localhost:3000/health || exit 1

CMD ["./docker-entrypoint.sh"]
