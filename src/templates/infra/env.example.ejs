# ============================================================
# Environment Configuration
# Copy this file to .env and update with your values
# ============================================================

# Application
NODE_ENV=development
PORT=3000

<% if (provider === 'sqlite') { -%>
# Database (SQLite)
DATABASE_URL="file:./dev.db"
<% } else if (provider === 'mysql') { -%>
# Database (MySQL)
DATABASE_URL="mysql://root:root@localhost:3306/<%= h.toSnakeCase(projectName || 'app') %>"
<% } else if (provider === 'mongodb') { -%>
# Database (MongoDB)
DATABASE_URL="mongodb://localhost:27017/<%= h.toSnakeCase(projectName || 'app') %>"
<% } else { -%>
# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/<%= h.toSnakeCase(projectName || 'app') %>?schema=public"
<% } -%>

<% const envHasAuth = schema.models.some(m => m.isAuthModel || m.directives.includes('protected') || m.directives.includes('auth')); -%>
<% const envHasAuthModel = schema.models.some(m => m.isAuthModel); -%>
<% const envHasCache = schema.models.some(m => m.cacheConfig != null); -%>
<% if (envHasAuth) { -%>
# Authentication
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
<% if (envHasAuthModel) { -%>
ACCESS_TOKEN_TTL="15m"
<% } -%>

<% } -%>
<% if (envHasAuthModel || envHasCache) { -%>
# Redis / Valkey
<% if (envHasAuthModel) { -%>
# Used for refresh token storage (supports multi-device sessions).
<% } -%>
<% if (envHasCache) { -%>
# Also used for response caching (@bcm.cache).
<% } -%>
REDIS_URL="redis://localhost:6379"

<% } -%>
# CORS
# Use an explicit origin when sending credentials from browsers
# (cookies or Authorization header). Example: http://localhost:5173
CORS_ORIGIN="*"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_MAX=100
