<% const dbName = h.toSnakeCase(projectName || 'app'); -%>
<% const needsRedis = hasCache || hasAuth || jobsProvider === 'bullmq'; -%>
<% const needsJwt = schema.models.some(m => m.isAuthModel || m.directives.includes('protected') || m.directives.includes('auth')); -%>
<% if (provider === 'sqlite') { -%>
services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=production
      - DATABASE_URL=file:./data/<%= dbName %>.db
<% if (needsJwt) { -%>
      - "JWT_SECRET=${JWT_SECRET:?JWT_SECRET must be set in .env (min 32 chars). Run: openssl rand -base64 32}"
<% } -%>
<% if (needsRedis) { -%>
      - REDIS_URL=redis://redis:6379
    depends_on:
      - redis
<% } -%>
    volumes:
      - appdata:/app/data
    restart: unless-stopped
<% if (needsRedis) { %>
  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    restart: unless-stopped
<% } %>
volumes:
  appdata:
<% } else if (provider === 'mysql') { -%>
# SECURITY: Set MYSQL_PASSWORD<% if (needsJwt) { %> and JWT_SECRET<% } %> in a .env file
# before deploying to production. Do not commit credentials to source control.
services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=production
      - DATABASE_URL=mysql://${MYSQL_USER:-root}:${MYSQL_PASSWORD:-root}@db:3306/<%= dbName %>
<% if (needsJwt) { -%>
      - "JWT_SECRET=${JWT_SECRET:?JWT_SECRET must be set in .env (min 32 chars). Run: openssl rand -base64 32}"
<% } -%>
<% if (needsRedis) { -%>
      - REDIS_URL=redis://redis:6379
<% } -%>
    depends_on:
      db:
        condition: service_healthy
<% if (needsRedis) { -%>
      redis:
        condition: service_started
<% } -%>
    restart: unless-stopped

  db:
    image: mysql:8
    environment:
      MYSQL_DATABASE: <%= dbName %>
      MYSQL_ROOT_PASSWORD: ${MYSQL_PASSWORD:-root}
    ports:
      - "${DB_PORT:-3306}:3306"
    volumes:
      - mysqldata:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 5s
      retries: 5
<% if (needsRedis) { %>
  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    restart: unless-stopped
<% } %>
volumes:
  mysqldata:
<% } else if (provider === 'mongodb') { -%>
# SECURITY: Set MONGO_PASSWORD<% if (needsJwt) { %> and JWT_SECRET<% } %> in a .env file
# before deploying to production. Do not commit credentials to source control.
services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=production
      - DATABASE_URL=mongodb://${MONGO_USER:-mongo}:${MONGO_PASSWORD:-mongo}@db:27017/<%= dbName %>?authSource=admin
<% if (needsJwt) { -%>
      - "JWT_SECRET=${JWT_SECRET:?JWT_SECRET must be set in .env (min 32 chars). Run: openssl rand -base64 32}"
<% } -%>
<% if (needsRedis) { -%>
      - REDIS_URL=redis://redis:6379
<% } -%>
    depends_on:
      db:
        condition: service_healthy
<% if (needsRedis) { -%>
      redis:
        condition: service_started
<% } -%>
    restart: unless-stopped

  db:
    image: mongo:7
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_USER:-mongo}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASSWORD:-mongo}
      MONGO_INITDB_DATABASE: <%= dbName %>
    ports:
      - "${DB_PORT:-27017}:27017"
    volumes:
      - mongodata:/data/db
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 5s
      timeout: 5s
      retries: 5
<% if (needsRedis) { %>
  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    restart: unless-stopped
<% } %>
volumes:
  mongodata:
<% } else { -%>
# SECURITY: Set POSTGRES_USER, POSTGRES_PASSWORD<% if (needsJwt) { %>, and JWT_SECRET<% } %> in a .env file
# before deploying to production. Do not commit credentials to source control.
services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=production
      - DATABASE_URL=postgresql://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@db:5432/<%= dbName %>?schema=public
<% if (needsJwt) { -%>
      - "JWT_SECRET=${JWT_SECRET:?JWT_SECRET must be set in .env (min 32 chars). Run: openssl rand -base64 32}"
<% } -%>
<% if (needsRedis) { -%>
      - REDIS_URL=redis://redis:6379
<% } -%>
    depends_on:
      db:
        condition: service_healthy
<% if (needsRedis) { -%>
      redis:
        condition: service_started
<% } -%>
    restart: unless-stopped

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: <%= dbName %>
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    ports:
      - "${DB_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 5s
      retries: 5
<% if (needsRedis) { %>
  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    restart: unless-stopped
<% } %>
volumes:
  pgdata:
<% } -%>
