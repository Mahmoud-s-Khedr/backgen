async function main() {
  const { env } = await import('./config/env.js');
<% const hasCache = schema.models.some((m) => m.cacheConfig != null); -%>
<% const hasAuth = schema.models.some((m) => m.isAuthModel); -%>
<% const needsRedis = hasCache || hasAuth; -%>
  const [{ app }, { prisma }, { logger }] = await Promise.all([
    import('./app.js'),
    import('./config/database.js'),
    import('./config/logger.js'),
  ]);
<% if (needsRedis) { -%>
  const { redisConnect, redis } = await import('./config/redis.js');
<% } -%>
  const PORT = env.PORT;

  // Verify database connection
  await prisma.$connect();
  logger.info('Database connected');
<% if (needsRedis) { -%>
  await redisConnect();
  logger.info('Redis connected');
<% } -%>
<% if (jobsProvider === 'bullmq') { -%>
  const { startWorkers } = await import('./jobs/worker.js');
  startWorkers();
<% } else if (jobsProvider === 'pg-boss') { -%>
  const { startWorkers } = await import('./jobs/worker.js');
  await startWorkers();
<% } -%>

  const server = app.listen(PORT, () => {
    logger.info({ port: PORT }, 'Server started');
    logger.info(`API docs: http://localhost:${PORT}/api/v1/docs`);
  });
<% if (wsEnabled) { -%>

  const { setupWebSocketServer } = await import('./ws/ws-server.js');
  setupWebSocketServer(server);
  await import('./ws/ws-broadcast.js');
  logger.info('WebSocket server attached');
<% } -%>

  // Graceful shutdown
  const shutdown = async (signal: string) => {
    logger.info({ signal }, 'Shutting down gracefully...');
    server.close(async () => {
<% if (wsEnabled) { -%>
      const { closeWebSocketServer } = await import('./ws/ws-server.js');
      closeWebSocketServer();
      logger.info('WebSocket server closed');
<% } -%>
<% if (jobsProvider === 'bullmq') { -%>
      const { closeAllQueues } = await import('./jobs/queue.js');
      await closeAllQueues();
      logger.info('Job queues closed');
<% } else if (jobsProvider === 'pg-boss') { -%>
      const { closeBoss } = await import('./jobs/queue.js');
      await closeBoss();
      logger.info('pg-boss stopped');
<% } -%>
<% if (needsRedis) { -%>
      await redis.quit();
      logger.info('Redis disconnected');
<% } -%>
      await prisma.$disconnect();
      logger.info('Database disconnected');
      process.exit(0);
    });

    // Force exit after timeout (configurable via SHUTDOWN_TIMEOUT env var)
    const timeout = parseInt(process.env.SHUTDOWN_TIMEOUT || '30000', 10);
    setTimeout(() => {
      logger.error('Forced shutdown after timeout');
      process.exit(1);
    }, timeout);
  };

  process.on('SIGTERM', () => shutdown('SIGTERM'));
  process.on('SIGINT', () => shutdown('SIGINT'));
}

main().catch(async (error) => {
  try {
    const { logger } = await import('./config/logger.js');
    logger.fatal({ error }, 'Failed to start server');
  } catch {
    console.error('Failed to start server');
    console.error(error);
  }
  process.exit(1);
});
