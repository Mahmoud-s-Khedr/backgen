import Fastify from 'fastify';
import cors from '@fastify/cors';
import helmet from '@fastify/helmet';
import compress from '@fastify/compress';
import rateLimit from '@fastify/rate-limit';
<% const hasAnyAuth = models.some((m) => m.isAuthModel || m.directives.includes('protected') || m.directives.includes('auth')); -%>
<% const hasUploads = models.some((m) => m.fields.some((f) => f.directives.includes('upload'))); -%>
<% if (hasAnyAuth) { -%>
import jwt from '@fastify/jwt';
<% } -%>
<% if (hasUploads) { -%>
import multipart from '@fastify/multipart';
<% } -%>
import { corsOptions } from './config/cors.js';
import { env } from './config/env.js';
import { setupSwagger } from './config/swagger.js';
import { errorHandler } from './middlewares/error.middleware.js';
<% for (const model of models) { -%>
import { <%= h.toCamelCase(model.name) %>Routes } from './modules/<%= h.toCamelCase(model.name) %>/<%= h.toCamelCase(model.name) %>.routes.js';
<% } -%>
<% if (hasAuthRoutes) { -%>
import { authRoutes } from './modules/auth/auth.routes.js';
<% } -%>

export async function buildApp() {
  const app = Fastify({
    logger: {
      level: process.env.LOG_LEVEL || 'info',
      ...(process.env.NODE_ENV === 'development'
        ? { transport: { target: 'pino-pretty', options: { colorize: true } } }
        : {}),
    },
    genReqId: () => crypto.randomUUID(),
    requestIdHeader: 'x-request-id',
  });

  // -- Security
  await app.register(helmet, { global: true });
  await app.register(cors, corsOptions);

  // -- Compression
  await app.register(compress);

  // -- Rate Limiting
  await app.register(rateLimit, { max: parseInt(process.env.RATE_LIMIT_MAX || '100', 10), timeWindow: '1 minute' });

<% if (hasAnyAuth) { -%>
  // -- JWT
  await app.register(jwt, { secret: env.JWT_SECRET });
<% } -%>
<% if (hasUploads) { -%>
  // -- Multipart uploads
  await app.register(multipart, {
    limits: { fileSize: 10 * 1024 * 1024, files: 1 },
  });
<% } -%>

  // -- Error Handler
  app.setErrorHandler(errorHandler);

  // -- Health Check
  app.get('/health', async () => ({
    status: 'ok',
    timestamp: new Date().toISOString(),
    uptime: process.uptime(),
  }));

  // -- Swagger
  await setupSwagger(app);

  // -- Routes (v1)
<% if (hasAuthRoutes) { -%>
  await app.register(authRoutes, { prefix: '/api/v1/auth' });
<% } -%>
<% for (const model of models) { -%>
  await app.register(<%= h.toCamelCase(model.name) %>Routes, { prefix: '/api/v1/<%= h.pluralize(h.toCamelCase(model.name)) %>' });
<% } -%>

  return app;
}
