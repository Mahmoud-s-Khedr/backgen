/**
 * Query Builder
 * Converts URL query parameters into Prisma findMany arguments.
 *
 * Supports: pagination, sorting, filtering, search, and relation includes.
 *
 * Examples:
 *   ?page=2&limit=20
 *   ?sort=createdAt&order=desc
 *   ?filter[status]=PUBLISHED&filter[authorId]=abc123
 *   ?search=hello
 *   ?include=author,comments
 */
export interface QueryOptions {
  where?: Record<string, any>;
  orderBy?: Record<string, string>;
  skip?: number;
  take: number;
  include?: Record<string, boolean>;
  page: number;
}

export function buildQueryOptions(
  query: Record<string, any>,
  allowedFilterFields: string[] = [],
  searchableFields: string[] = [],
): QueryOptions {
  const page = Math.max(1, parseInt(query.page || '1', 10));
  const limit = Math.min(100, Math.max(1, parseInt(query.limit || '20', 10)));
  const skip = (page - 1) * limit;

  // Sorting — validate sort field against allowed fields
  const sortField = query.sort || 'id';
  const sort = allowedFilterFields.length === 0 || allowedFilterFields.includes(sortField)
    ? sortField
    : 'id';
  const order = query.order === 'asc' ? 'asc' : 'desc';
  const orderBy = { [sort]: order };

  // Filtering — only allow known fields
  const where: Record<string, any> = {};
  if (query.filter && typeof query.filter === 'object') {
    for (const [key, value] of Object.entries(query.filter)) {
      if (allowedFilterFields.length > 0 && !allowedFilterFields.includes(key)) {
        continue; // Skip unknown filter fields
      }
      if (typeof value === 'string') {
        const num = Number(value);
        if (!isNaN(num)) {
          where[key] = num;
        } else if (value === 'true' || value === 'false') {
          where[key] = value === 'true';
        } else {
<% if (datasource.provider === 'postgresql' || datasource.provider === 'mysql') { %>
          where[key] = { contains: value, mode: 'insensitive' };
<% } else { %>
          where[key] = { contains: value };
<% } %>
        }
      }
    }
  }

  // Full-text search across searchable fields
  if (query.search && typeof query.search === 'string' && searchableFields.length > 0) {
    const searchTerm = query.search;
    const searchConditions = searchableFields.map((field) => ({
<% if (datasource.provider === 'postgresql' || datasource.provider === 'mysql') { %>
      [field]: { contains: searchTerm, mode: 'insensitive' as const },
<% } else { %>
      [field]: { contains: searchTerm },
<% } %>
    }));
    where.OR = searchConditions;
  }

  // Includes
  let include: Record<string, boolean> | undefined;
  if (query.include) {
    include = {};
    const relations = query.include.split(',').map((r: string) => r.trim());
    for (const relation of relations) {
      include[relation] = true;
    }
  }

  return { where, orderBy, skip, take: limit, include, page };
}
