{
  "name": "<%= h.toKebabCase(projectName || 'api-server') %>",
  "version": "1.0.0",
  "description": "Generated REST API server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "pretest": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6",
<% if (provider === 'sqlite') { %>
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "better-sqlite3": "^12.0.0",<% } else if (provider === 'postgresql' || provider === 'cockroachdb') { %>
    "@prisma/adapter-pg": "^7.4.2",
    "pg": "^8.13.0",<% } else if (provider === 'mysql') { %>
    "@prisma/adapter-mariadb": "^7.4.2",<% } %>
<% if (framework === 'fastify') { %>
    "fastify": "^5.8.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "pino-http": "^11.0.0"<% if (hasUploads) { %>,
    "@fastify/multipart": "^9.0.0",
    "@aws-sdk/client-s3": "^3.1005.0"<% } %><% } else { %>
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1"<% if (hasUploads) { %>,
    "multer": "^2.1.1",
    "@aws-sdk/client-s3": "^3.1005.0"<% } %><% } %><% if (hasCache || hasAuth) { %>,
    "redis": "^5.11.0"<% } %>
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "vitest": "^4.0.18",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"<% if (framework !== 'fastify') { %>,
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/swagger-ui-express": "^4.1.6"<% if (hasUploads) { %>,
    "@types/multer": "^1.4.12"<% } %><% } %><% if (provider === 'postgresql' || provider === 'cockroachdb') { %>,
    "@types/pg": "^8.11.0"<% } %><% if (provider === 'sqlite') { %>,
    "@types/better-sqlite3": "^7.6.0"<% } %>
  },
  "pnpm": {
    "onlyBuiltDependencies": [<% const pnpmBuiltDependencies = ['prisma', '@prisma/engines']; if (provider === 'sqlite') pnpmBuiltDependencies.push('better-sqlite3'); -%><%= pnpmBuiltDependencies.map((dependency) => JSON.stringify(dependency)).join(', ') %>]
  }
}
