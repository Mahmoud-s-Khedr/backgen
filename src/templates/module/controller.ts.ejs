import { Request, Response, NextFunction } from 'express';
import { <%= model.name %>Service } from './<%= h.toCamelCase(model.name) %>.service.js';
import { <%= model.name %>ResponseSchema, <%= model.name %>WithIncludesResponseSchema } from './<%= h.toCamelCase(model.name) %>.dto.js';
import { buildQueryOptions } from '../../utils/query-builder.js';
import { sendSuccess, sendCreated, sendNoContent } from '../../utils/response.js';
<% if (itemSelector) { -%>
import { ProblemDetail } from '../../middlewares/error.middleware.js';
<% } -%>

const service = new <%= model.name %>Service();

/** Allowed fields for filtering and sorting — prevents querying on hidden/writeOnly fields. */
const ALLOWED_FILTER_FIELDS = [<%- filterableFields.map(f => `'${f}'`).join(', ') %>];
const SEARCHABLE_FIELDS: string[] = [<%- searchableFields.map(f => `'${f}'`).join(', ') %>];
const ALLOWED_INCLUDE_RELATIONS: string[] = [<%- includeRelations.map(f => `'${f.name}'`).join(', ') %>];
const FILTER_FIELD_TYPES = {
<% for (const [fieldName, fieldType] of Object.entries(filterFieldTypes)) { -%>
  <%= fieldName %>: '<%= fieldType %>',
<% } -%>
} as const;
const DEFAULT_SORT_FIELD: string | undefined = <%= defaultSortField ? `'${defaultSortField}'` : 'undefined' %>;

/**
 * <%= model.name %> Controller
 * Handles HTTP request/response for the <%= model.name %> resource.
 */
export class <%= model.name %>Controller {
<% if (itemSelector) { -%>
  private invalidSelectorParam(fieldName: string, expected: string): ProblemDetail {
    return new ProblemDetail({
      type: 'validation-error',
      title: 'Validation Error',
      status: 422,
      detail: `Invalid selector parameter "${fieldName}". Expected ${expected}.`,
    });
  }

  private parseSelectorParam(
    rawValue: string | undefined,
    fieldName: string,
    fieldType: 'string' | 'enum' | 'number' | 'bigint' | 'boolean' | 'datetime' | 'other',
  ): string | number | bigint | boolean | Date {
    if (rawValue === undefined) {
      throw this.invalidSelectorParam(fieldName, 'a value');
    }
    if (fieldType === 'number') {
      const num = Number(rawValue);
      if (!Number.isFinite(num)) {
        throw this.invalidSelectorParam(fieldName, 'a numeric value');
      }
      return num;
    }
    if (fieldType === 'bigint') {
      try {
        return BigInt(rawValue);
      } catch {
        throw this.invalidSelectorParam(fieldName, 'an integer value');
      }
    }
    if (fieldType === 'boolean') {
      if (rawValue === 'true') return true;
      if (rawValue === 'false') return false;
      throw this.invalidSelectorParam(fieldName, 'true or false');
    }
    if (fieldType === 'datetime') {
      const date = new Date(rawValue);
      if (Number.isNaN(date.getTime())) {
        throw this.invalidSelectorParam(fieldName, 'an ISO datetime value');
      }
      return date;
    }
    return rawValue;
  }

  private readKeyFromParams(req: Request): {
<% for (const fieldMeta of itemSelectorFieldMeta) { -%>
    <%= fieldMeta.name %>: <%= fieldMeta.tsType %>;
<% } -%>
  } {
    return {
<% for (const fieldMeta of itemSelectorFieldMeta) { -%>
      <%= fieldMeta.name %>: this.parseSelectorParam(
        req.params.<%= fieldMeta.name %>,
        '<%= fieldMeta.name %>',
        '<%= fieldMeta.filterType %>'
      ) as <%= fieldMeta.tsType %>,
<% } -%>
    };
  }

  private keyDescription(req: Request): string {
<% if (itemSelector.fields.length === 1) { -%>
    return `<%= itemSelector.fields[0] %>=\"${req.params.<%= itemSelector.fields[0] %>}\"`;
<% } else { -%>
    return `<%= itemSelector.fields.map((f) => `${f}=\\\"\${req.params.${f}}\\\"`).join(', ') %>`;
<% } -%>
  }

<% } -%>
  /**
   * GET /api/<%= h.pluralize(h.toCamelCase(model.name)) %>
   */
  async list(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      const options = buildQueryOptions(req.query, {
        allowedFilterFields: ALLOWED_FILTER_FIELDS,
        searchableFields: SEARCHABLE_FIELDS,
        allowedIncludeRelations: ALLOWED_INCLUDE_RELATIONS,
        filterFieldTypes: FILTER_FIELD_TYPES,
        defaultSortField: DEFAULT_SORT_FIELD,
      });
      const { data, total } = await service.findMany(options);
      const hasInclude = !!options.include && Object.keys(options.include).length > 0;
      const safeData = data.map((item: unknown) =>
        hasInclude
          ? <%= model.name %>WithIncludesResponseSchema.parse(item)
          : <%= model.name %>ResponseSchema.parse(item)
      );
      sendSuccess(res, safeData, {
        page: options.page,
        limit: options.take,
        total,
        totalPages: Math.ceil(total / (options.take || 20)),
      });
    } catch (error) {
      next(error);
    }
  }

<% if (itemSelector) { -%>
  /**
   * GET /api/<%= h.pluralize(h.toCamelCase(model.name)) %><%= itemPath %>
   */
  async getOne(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      const options = buildQueryOptions(req.query, {
        allowedFilterFields: ALLOWED_FILTER_FIELDS,
        searchableFields: SEARCHABLE_FIELDS,
        allowedIncludeRelations: ALLOWED_INCLUDE_RELATIONS,
        filterFieldTypes: FILTER_FIELD_TYPES,
        defaultSortField: DEFAULT_SORT_FIELD,
      });
      const result = await service.findOne(this.readKeyFromParams(req), options.include);
      if (!result) {
        throw new ProblemDetail({
          type: 'not-found',
          title: 'Not Found',
          status: 404,
          detail: `<%= model.name %> with key "${this.keyDescription(req)}" not found.`,
        });
      }
      const hasInclude = !!options.include && Object.keys(options.include).length > 0;
      sendSuccess(
        res,
        hasInclude
          ? <%= model.name %>WithIncludesResponseSchema.parse(result)
          : <%= model.name %>ResponseSchema.parse(result)
      );
    } catch (error) {
      next(error);
    }
  }
<% } -%>

  /**
   * POST /api/<%= h.pluralize(h.toCamelCase(model.name)) %>
   */
  async create(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      const result = await service.create(req.body);
      sendCreated(res, <%= model.name %>ResponseSchema.parse(result));
    } catch (error) {
      next(error);
    }
  }

<% if (itemSelector) { -%>
  /**
   * PUT /api/<%= h.pluralize(h.toCamelCase(model.name)) %><%= itemPath %>
   */
  async update(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      const result = await service.update(this.readKeyFromParams(req), req.body);
      sendSuccess(res, <%= model.name %>ResponseSchema.parse(result));
    } catch (error) {
      next(error);
    }
  }

  /**
   * PATCH /api/<%= h.pluralize(h.toCamelCase(model.name)) %><%= itemPath %>
   */
  async patch(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      const result = await service.update(this.readKeyFromParams(req), req.body);
      sendSuccess(res, <%= model.name %>ResponseSchema.parse(result));
    } catch (error) {
      next(error);
    }
  }

  /**
   * DELETE /api/<%= h.pluralize(h.toCamelCase(model.name)) %><%= itemPath %>
   */
  async remove(req: Request, res: Response, next: NextFunction): Promise<void> {
    try {
      await service.delete(this.readKeyFromParams(req));
      sendNoContent(res);
    } catch (error) {
      next(error);
    }
  }
<% } -%>
}
