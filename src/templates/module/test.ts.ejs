<%
// Preliminary: detect if jwt/env imports are needed (current model or any transitive FK dep is auth-guarded).
// This block runs first so _needsAuthImport is available for the import section below.
function _modelNeedsAuth(md) {
  return md && (md.directives.includes('protected') || md.directives.includes('auth'));
}
function _hasAuthDep(modelName, vis) {
  if (!vis) vis = new Set();
  if (vis.has(modelName)) return false;
  vis.add(modelName);
  const md = allModels.find(m => m.name === modelName);
  if (!md) return false;
  for (const rf of md.fields) {
    if (rf.isList || !rf.relationField) continue;
    const fk = md.fields.find(f => f.name === rf.relationField);
    if (!fk || fk.isOptional || fk.hasDefault || fk.isServerDefault) continue;
    const pmd = allModels.find(m => m.name === rf.type);
    if (!pmd) continue;
    if (_modelNeedsAuth(pmd)) return true;
    if (_hasAuthDep(rf.type, vis)) return true;
  }
  return false;
}
const _needsAuthImport = isProtected || _hasAuthDep(model.name);
%>
import request from 'supertest';
import { app } from '../../app.js';
<% if (_needsAuthImport) { -%>
import jwt from 'jsonwebtoken';
import { env } from '../../config/env.js';
<% } -%>

/**
 * <%= model.name %> API Tests
 * Scaffolded test file using supertest.
 * TODO: Set up test database and implement proper test fixtures.
 */
<% if (isProtected) { -%>
const _authToken = jwt.sign({ id: 'test-user-id', role: '<%= authRoles.length > 0 ? authRoles[0] : "USER" %>' }, env.JWT_SECRET);
<% } -%>
const _testId = Date.now().toString(36) + Math.random().toString(36).slice(2, 7);

<%
function sampleValue(field) {
  if (field.type === 'String') return `'test-${field.name}-' + _testId`;
  if (field.type === 'Int') return '1';
  if (field.type === 'Float' || field.type === 'Decimal') return '1.5';
  if (field.type === 'Boolean') return 'true';
  if (field.type === 'DateTime') return `new Date().toISOString()`;
  if (field.type === 'BigInt') return '1';
  if (field.isEnum) {
    const enumDef = enums.find(e => e.name === field.type);
    if (enumDef && enumDef.values.length > 0) return `'${enumDef.values[0]}'`;
  }
  return `'test-${field.name}'`;
}

const requiredCreateFields = createFields.filter(f => !f.isRelation && !f.isOptional && !f.hasDefault);
const optionalCreateFields = createFields.filter(f => !f.isRelation && (f.isOptional || f.hasDefault));

// Build a topologically-sorted list of ALL models that must be created before the current one,
// including transitive FK dependencies (e.g. Task→Project→User).
// Each entry: { targetModel, varName, apiPath, fields: [{name, isFK, depVarName?, field?}] }
function computeAllDeps(startModelName) {
  const allDepsOrdered = [];
  const processedModels = new Set();

  function visit(modelName) {
    if (processedModels.has(modelName)) return;
    processedModels.add(modelName);

    const modelDef = allModels.find(m => m.name === modelName);
    if (!modelDef) return;

    for (const relField of modelDef.fields) {
      if (relField.isList || !relField.relationField) continue;
      const fkScalarField = modelDef.fields.find(f => f.name === relField.relationField);
      // Only handle required (non-optional, no default, no server default) FK fields
      if (!fkScalarField || fkScalarField.isOptional || fkScalarField.hasDefault || fkScalarField.isServerDefault) continue;

      // Recurse into parent's deps BEFORE adding parent itself (topological order)
      visit(relField.type);

      const parentVarName = '_' + relField.type.charAt(0).toLowerCase() + relField.type.slice(1) + 'Id';
      if (allDepsOrdered.find(d => d.varName === parentVarName)) continue;

      const parentModelDef = allModels.find(m => m.name === relField.type);
      if (!parentModelDef) continue;

      // Build the payload field list for creating the parent model:
      // required non-id non-readonly non-hidden non-serverDefault fields.
      // FK scalar fields are flagged with isFK=true and reference their dep's varName.
      const parentRequiredFields = parentModelDef.fields
        .filter(f =>
          !f.isRelation &&
          !f.isId &&
          !f.isOptional &&
          !f.hasDefault &&
          !f.isServerDefault &&
          !f.directives.includes('hidden') &&
          !f.directives.includes('readonly')
        )
        .map(f => {
          // Is this field a FK? (i.e. it is the relationField of some required non-list relation)
          const owningRelation = parentModelDef.fields.find(
            rf => rf.isRelation && !rf.isList && rf.relationField === f.name
          );
          if (owningRelation) {
            const sfk = parentModelDef.fields.find(sf => sf.name === f.name);
            if (sfk && !sfk.isOptional && !sfk.hasDefault && !sfk.isServerDefault) {
              const depVarName = '_' + owningRelation.type.charAt(0).toLowerCase() + owningRelation.type.slice(1) + 'Id';
              return { name: f.name, isFK: true, depVarName };
            }
          }
          return { name: f.name, isFK: false, field: f };
        });

      const parentIsAuth = parentModelDef.directives.includes('protected') || parentModelDef.directives.includes('auth');
      const parentAuthRoles = parentModelDef.authRoles ?? [];
      allDepsOrdered.push({
        targetModel: relField.type,
        varName: parentVarName,
        apiPath: '/api/' + h.pluralize(h.toCamelCase(relField.type)),
        fields: parentRequiredFields,
        needsAuth: parentIsAuth,
        depAuthRoles: parentAuthRoles,
      });
    }
  }

  visit(startModelName);
  return allDepsOrdered;
}

const allDeps = computeAllDeps(model.name);

// Compute the role to use when creating protected parent records in beforeAll.
// Use the first role from any @bcm.auth dep; fall back to 'USER' for @bcm.protected (any valid JWT).
const _setupTokenRole = (() => {
  for (const dep of allDeps) {
    if (dep.needsAuth && dep.depAuthRoles.length > 0) return dep.depAuthRoles[0];
  }
  return 'USER';
})();

// Direct FK deps of the current model only (for validPayload)
const directFkDeps = [];
for (const relField of relationFields) {
  if (relField.isList || !relField.relationField) continue;
  const reqFkField = requiredCreateFields.find(f => f.name === relField.relationField);
  if (!reqFkField) continue;
  if (directFkDeps.find(d => d.fkFieldName === relField.relationField)) continue;
  directFkDeps.push({
    fkFieldName: relField.relationField,
    varName: '_' + relField.type.charAt(0).toLowerCase() + relField.type.slice(1) + 'Id',
  });
}
-%>
<% if (allDeps.some(d => d.needsAuth)) { -%>
const _setupToken = jwt.sign({ id: 'test-user-id', role: '<%= _setupTokenRole %>' }, env.JWT_SECRET);
<% } -%>
<% for (const dep of allDeps) { -%>
let <%= dep.varName %>: string;
<% } -%>
describe('<%= model.name %> API', () => {
  const basePath = '/api/<%= h.pluralize(h.toCamelCase(model.name)) %>';
<% if (allDeps.length > 0) { %>
  beforeAll(async () => {
<% for (const dep of allDeps) { %>    // Create parent <%= dep.targetModel %> (required by FK dependency chain)
    const _<%= dep.targetModel.toLowerCase() %>Res = await request(app)
      .post('<%= dep.apiPath %>')
      .send({
<% for (const f of dep.fields) { -%>
<% if (f.isFK) { -%>
        <%= f.name %>: <%= f.depVarName %>,
<% } else { -%>
        <%= f.name %>: <%- sampleValue(f.field) %>,
<% } -%>
<% } -%>
      })
      .set('Content-Type', 'application/json')<% if (dep.needsAuth) { %>
      .set('Authorization', `Bearer ${_setupToken}`)<% } %>;
    <%= dep.varName %> = _<%= dep.targetModel.toLowerCase() %>Res.body.data?.id;
<% } %>  });
<% } %>
  /** Helper: build a valid payload with required fields */
  function validPayload() {
    return {
<% for (const field of requiredCreateFields) {
  const fkDep = directFkDeps.find(d => d.fkFieldName === field.name);
-%>
      <%= field.name %>: <%- fkDep ? fkDep.varName : sampleValue(field) %>,
<% } -%>
    };
  }

  describe('GET ' + basePath, () => {
    it('should return a paginated list', async () => {
      const response = await request(app)
        .get(basePath)
        .query({ page: 1, limit: 10 });

      expect(response.status).toBe(200);
      expect(response.body).toHaveProperty('data');
      expect(response.body).toHaveProperty('meta');
      expect(Array.isArray(response.body.data)).toBe(true);
      expect(response.body.meta).toHaveProperty('page');
      expect(response.body.meta).toHaveProperty('total');
    });
  });

  describe('POST ' + basePath, () => {
    it('should create a new <%= h.toCamelCase(model.name) %>', async () => {
      const response = await request(app)
        .post(basePath)
        .send(validPayload())
        .set('Content-Type', 'application/json')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;

      expect(response.status).toBe(201);
      expect(response.body).toHaveProperty('data');
    });

    it('should return 422 for invalid/empty body', async () => {
      const response = await request(app)
        .post(basePath)
        .send({})
        .set('Content-Type', 'application/json')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;

      expect(response.status).toBe(422);
      expect(response.body).toHaveProperty('type', 'validation-error');
      expect(response.body).toHaveProperty('errors');
    });
  });

  describe('GET ' + basePath + '/:id', () => {
    it('should return 404 for non-existent ID', async () => {
      const response = await request(app).get(basePath + '/non-existent-id');
      expect(response.status).toBe(404);
      expect(response.body).toHaveProperty('status', 404);
    });
  });

  describe('PUT ' + basePath + '/:id', () => {
    it('should return 404 for non-existent ID', async () => {
      const response = await request(app)
        .put(basePath + '/non-existent-id')
        .send(validPayload())
        .set('Content-Type', 'application/json')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;

      expect(response.status).toBe(404);
    });

    it('should return 422 for invalid body', async () => {
      const response = await request(app)
        .put(basePath + '/some-id')
        .send({})
        .set('Content-Type', 'application/json')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;

      expect(response.status).toBe(422);
    });
  });

  describe('PATCH ' + basePath + '/:id', () => {
    it('should return 404 for non-existent ID', async () => {
      const response = await request(app)
        .patch(basePath + '/non-existent-id')
        .send({ <%= requiredCreateFields.length > 0 ? `${requiredCreateFields[0].name}: ${sampleValue(requiredCreateFields[0])}` : '' %> })
        .set('Content-Type', 'application/json')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;

      expect(response.status).toBe(404);
    });
  });

  describe('DELETE ' + basePath + '/:id', () => {
    it('should return 404 for non-existent ID', async () => {
      const response = await request(app)
        .delete(basePath + '/non-existent-id')<% if (isProtected) { %>
        .set('Authorization', `Bearer ${_authToken}`)<% } %>;
      expect(response.status).toBe(404);
    });
  });
});
