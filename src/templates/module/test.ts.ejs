<%
function sampleValue(field) {
  if (field.type === 'String') return `'test-${field.name}-' + testId`;
  if (field.type === 'Int') return '1';
  if (field.type === 'Float' || field.type === 'Decimal') return '1.5';
  if (field.type === 'Boolean') return 'true';
  if (field.type === 'DateTime') return 'new Date("2024-01-01T00:00:00.000Z").toISOString()';
  if (field.type === 'BigInt') return '1n';
  if (field.isEnum) {
    const enumDef = enums.find(e => e.name === field.type);
    if (enumDef && enumDef.values.length > 0) return `'${enumDef.values[0]}'`;
  }
  return `'test-${field.name}'`;
}

function selectorSampleValue(fieldMeta) {
  if (fieldMeta.filterType === 'number') return '1';
  if (fieldMeta.filterType === 'bigint') return '1n';
  if (fieldMeta.filterType === 'boolean') return 'true';
  if (fieldMeta.filterType === 'datetime') return 'new Date("2024-01-01T00:00:00.000Z")';
  return `'existing-${fieldMeta.name}'`;
}

function relationFieldNames(relationField) {
  if (!relationField || typeof relationField !== 'string') return [];
  return relationField.split(',').map((name) => name.trim()).filter(Boolean);
}

function targetCreateFieldsForRelation(relation) {
  const targetModel = allModels.find((m) => m.name === relation.relationModel);
  if (!targetModel) return [];
  return targetModel.fields.filter(
    (field) =>
      !field.isRelation &&
      !field.isId &&
      !field.directives.includes('hidden') &&
      !field.directives.includes('readonly') &&
      (!field.isServerDefault || field.directives.includes('writeOnly'))
  );
}

function nestedCreatePayloadExpr(relation) {
  const targetCreateFields = targetCreateFieldsForRelation(relation);
  const inner = targetCreateFields.map((field) => `${field.name}: ${sampleValue(field)}`).join(', ');
  if (relation.isList) {
    return `{ create: [{ ${inner} }] }`;
  }
  return `{ create: { ${inner} } }`;
}

const requiredCreateFields = createFields.filter((field) => !field.isRelation && !field.isOptional && !field.hasDefault);
const requiredNestedRelations = nestedRelations.filter((relation) => {
  const nestedFk = relationFieldNames(relation.relationField);
  if (nestedFk.length === 0) return false;
  return nestedFk.every((fieldName) => {
    const field = model.fields.find((candidate) => candidate.name === fieldName);
    return !!field && !field.isOptional && !field.hasDefault && !field.isServerDefault;
  });
});
const hasRequiredCreateInput = requiredCreateFields.length > 0 || requiredNestedRelations.length > 0;
-%>
import { beforeEach, describe, expect, it, vi } from 'vitest';
import request from 'supertest';
<% if (isProtected) { -%>
import jwt from 'jsonwebtoken';
import { env } from '../../config/env.js';
<% } -%>

type PrismaDelegateMock = {
  findMany: ReturnType<typeof vi.fn>;
  count: ReturnType<typeof vi.fn>;
  findUnique: ReturnType<typeof vi.fn>;
  findFirst: ReturnType<typeof vi.fn>;
  create: ReturnType<typeof vi.fn>;
  update: ReturnType<typeof vi.fn>;
  delete: ReturnType<typeof vi.fn>;
};

function createDelegateMock(): PrismaDelegateMock {
  return {
    findMany: vi.fn(),
    count: vi.fn(),
    findUnique: vi.fn(),
    findFirst: vi.fn(),
    create: vi.fn(),
    update: vi.fn(),
    delete: vi.fn(),
  };
}

const prismaMock: Record<string, PrismaDelegateMock> = {
<% for (const candidateModel of allModels) { -%>
  <%= h.toCamelCase(candidateModel.name) %>: createDelegateMock(),
<% } -%>
};

vi.mock('../../config/database.js', () => ({
  prisma: prismaMock,
}));

const { app } = await import('../../app.js');

<% if (isProtected) { -%>
const authToken = jwt.sign(
  { id: 'test-user-id', role: '<%= authRoles.length > 0 ? authRoles[0] : "USER" %>' },
  env.JWT_SECRET
);
<% } -%>
const testId = Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
const modelDelegate = prismaMock.<%= modelLower %>;

beforeEach(() => {
  for (const delegate of Object.values(prismaMock)) {
    delegate.findMany.mockReset();
    delegate.count.mockReset();
    delegate.findUnique.mockReset();
    delegate.findFirst.mockReset();
    delegate.create.mockReset();
    delegate.update.mockReset();
    delegate.delete.mockReset();
  }
});

function mockRecord(overrides: Record<string, unknown> = {}) {
  return {
<% for (const field of responseFields) { -%>
<% if (field.isRelation) continue; -%>
    <%= field.name %>: <%- sampleValue(field) %>,
<% } -%>
    ...overrides,
  };
}

function validPayload() {
  return {
<% for (const field of requiredCreateFields) { -%>
    <%= field.name %>: <%- sampleValue(field) %>,
<% } -%>
<% for (const relation of requiredNestedRelations) { -%>
    <%= relation.name %>: <%- nestedCreatePayloadExpr(relation) %>,
<% } -%>
  };
}

describe('<%= model.name %> API', () => {
  const basePath = '/api/<%= h.pluralize(h.toCamelCase(model.name)) %>';
<% if (itemSelector) { -%>
  const existingKey = {
<% for (const fieldMeta of itemSelectorFieldMeta) { -%>
    <%= fieldMeta.name %>: <%- selectorSampleValue(fieldMeta) %>,
<% } -%>
  };
  const missingKey = {
<% for (const fieldMeta of itemSelectorFieldMeta) { -%>
    <%= fieldMeta.name %>: <%- fieldMeta.filterType === 'number' ? '999999' : fieldMeta.filterType === 'bigint' ? '999999n' : fieldMeta.filterType === 'boolean' ? 'false' : fieldMeta.filterType === 'datetime' ? 'new Date("2030-01-01T00:00:00.000Z")' : `'missing-${fieldMeta.name}'` %>,
<% } -%>
  };
  function buildItemPath(key: typeof existingKey): string {
    return basePath + '<%= itemPath %>'
<% for (const fieldMeta of itemSelectorFieldMeta) { -%>
      .replace(':<%= fieldMeta.name %>', encodeURIComponent(String(key.<%= fieldMeta.name %>)))
<% } -%>
    ;
  }
  const existingItemPath = buildItemPath(existingKey);
  const missingItemPath = buildItemPath(missingKey);
<% } -%>

  describe('GET ' + basePath, () => {
    it('returns a paginated list from mocked Prisma delegates', async () => {
      modelDelegate.findMany.mockResolvedValue([mockRecord()]);
      modelDelegate.count.mockResolvedValue(1);

      const requestBuilder = request(app).get(basePath).query({ page: 1, limit: 10 });
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(200);
      expect(response.body).toHaveProperty('data');
      expect(response.body).toHaveProperty('meta');
      expect(response.body.meta).toMatchObject({ page: 1, limit: 10, total: 1, totalPages: 1 });
      expect(modelDelegate.findMany).toHaveBeenCalledTimes(1);
      expect(modelDelegate.count).toHaveBeenCalledTimes(1);
    });
  });

  describe('POST ' + basePath, () => {
    it('creates a new <%= h.toCamelCase(model.name) %> with mocked Prisma', async () => {
      modelDelegate.create.mockResolvedValue(mockRecord());

      const requestBuilder = request(app)
        .post(basePath)
        .send(validPayload())
        .set('Content-Type', 'application/json');
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(201);
      expect(response.body).toHaveProperty('data');
      expect(modelDelegate.create).toHaveBeenCalledTimes(1);
    });

<% if (hasRequiredCreateInput) { -%>
    it('returns 422 for an invalid body before hitting Prisma', async () => {
      const requestBuilder = request(app)
        .post(basePath)
        .send({})
        .set('Content-Type', 'application/json');
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(422);
      expect(modelDelegate.create).not.toHaveBeenCalled();
    });
<% } else { -%>
    it('accepts an empty body when the schema has no required create fields', async () => {
      modelDelegate.create.mockResolvedValue(mockRecord());

      const requestBuilder = request(app)
        .post(basePath)
        .send({})
        .set('Content-Type', 'application/json');
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(201);
      expect(modelDelegate.create).toHaveBeenCalledTimes(1);
    });
<% } -%>
  });

<% if (itemSelector) { -%>
  describe('GET ' + existingItemPath, () => {
    it('returns a single record from mocked Prisma', async () => {
<% if (isSoftDelete) { -%>
      modelDelegate.findFirst.mockResolvedValue(mockRecord(existingKey));
<% } else { -%>
      modelDelegate.findUnique.mockResolvedValue(mockRecord(existingKey));
<% } -%>

      const requestBuilder = request(app).get(existingItemPath);
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(200);
      expect(response.body).toHaveProperty('data');
    });

    it('returns 404 when the mocked record does not exist', async () => {
<% if (isSoftDelete) { -%>
      modelDelegate.findFirst.mockResolvedValue(null);
<% } else { -%>
      modelDelegate.findUnique.mockResolvedValue(null);
<% } -%>

      const requestBuilder = request(app).get(missingItemPath);
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(404);
    });
  });

  describe('PUT ' + existingItemPath, () => {
    it('returns 404 when mocked Prisma reports a missing record', async () => {
      modelDelegate.update.mockRejectedValue({ code: 'P2025' });

      const requestBuilder = request(app)
        .put(missingItemPath)
        .send(validPayload())
        .set('Content-Type', 'application/json');
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(404);
    });
  });

  describe('DELETE ' + existingItemPath, () => {
    it('returns 404 when mocked Prisma reports a missing record', async () => {
<% if (isSoftDelete) { -%>
      modelDelegate.update.mockRejectedValue({ code: 'P2025' });
<% } else { -%>
      modelDelegate.delete.mockRejectedValue({ code: 'P2025' });
<% } -%>

      const requestBuilder = request(app).delete(missingItemPath);
<% if (isProtected) { -%>
      requestBuilder.set('Authorization', `Bearer ${authToken}`);
<% } -%>
      const response = await requestBuilder;

      expect(response.status).toBe(404);
    });
  });
<% } -%>
});
