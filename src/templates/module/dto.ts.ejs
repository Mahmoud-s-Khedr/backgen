import { z } from 'zod';

/**
 * <%= model.name %> DTOs (Data Transfer Objects)
 * Zod schemas for request validation and response shaping.
 */
<%
const requiredEnumNames = new Set(
  model.fields
    .filter(f => !f.isRelation)
    .map(f => f.type)
    .filter(type => enums.some(e => e.name === type))
);
for (const nr of nestedRelations) {
  const targetModel = allModels.find(m => m.name === nr.relationModel);
  if (!targetModel) continue;
  const targetCreateFields = targetModel.fields.filter(
    f => !f.isRelation && !f.isId && !f.directives.includes('hidden') && !f.directives.includes('readonly') && (!f.isServerDefault || f.directives.includes('writeOnly'))
  );
  for (const f of targetCreateFields) {
    if (enums.some(e => e.name === f.type)) {
      requiredEnumNames.add(f.type);
    }
  }
}
for (const relation of includeRelations) {
  const targetModel = allModels.find(m => m.name === relation.relationModel);
  if (!targetModel) continue;
  const targetResponseFields = targetModel.fields.filter(
    f => !f.isRelation && !f.directives.includes('hidden') && !f.directives.includes('writeOnly')
  );
  for (const f of targetResponseFields) {
    if (enums.some(e => e.name === f.type)) {
      requiredEnumNames.add(f.type);
    }
  }
}

function getFieldZodType(field, options = {}) {
  const enumDef = enums.find(e => e.name === field.type);
  let zodType = enumDef
    ? `${enumDef.name}Schema`
    : (options.coerceDate && field.type === 'DateTime'
      ? 'z.coerce.date()'
      : h.prismaToZodType(field.type));
  if (field.isList) {
    zodType = `z.array(${zodType})`;
  }
  return zodType;
}
-%>
<% for (const enumDef of enums) { -%>
<% if (requiredEnumNames.has(enumDef.name)) { -%>

export const <%= enumDef.name %>Schema = z.enum([<%= enumDef.values.map(v => `'${v}'`).join(', ') %>]);
<% } -%>
<% } -%>

<% for (const nr of nestedRelations) { -%>
<% const targetModel = allModels.find(m => m.name === nr.relationModel); -%>
<% if (targetModel) { -%>
<% const targetCreateFields = targetModel.fields.filter(f => !f.isRelation && !f.isId && !f.directives.includes('hidden') && !f.directives.includes('readonly') && (!f.isServerDefault || f.directives.includes('writeOnly'))); -%>
<% const connectMeta = nestedRelationConnectMeta[nr.name]; -%>
/**
 * Nested input for <%= nr.name %> relation on <%= model.name %>.
 * Supports Prisma's nested create syntax<%= connectMeta && connectMeta.hasConnect ? ' or selector-aware connect syntax' : '' %>.
 */
<% if (connectMeta && connectMeta.hasConnect && connectMeta.selector) { -%>
export const <%= model.name %>_<%= h.toPascalCase(nr.name) %>Input = z.object({
  create: <%= nr.isList ? 'z.array(' : '' %>z.object({
<% for (const f of targetCreateFields) { -%>
<% const zt = getFieldZodType(f); const io = f.isOptional || f.hasDefault; -%>
    <%= f.name %>: <%= zt %><%= io ? '.optional()' : '' %>,
<% } -%>
  })<%= nr.isList ? ').min(1)' : '' %>.optional(),
  connect: <%= nr.isList ? 'z.array(' : '' %>z.object({
<% if (connectMeta.selector.isComposite) { -%>
    <%= connectMeta.selector.prismaWhereKey || connectMeta.selector.fields.map((f) => f.name).join('_') %>: z.object({
<% for (const selectorField of connectMeta.selector.fields) { -%>
<% const sf = targetModel.fields.find(f => f.name === selectorField.name); const zodType = sf ? getFieldZodType(sf) : 'z.string()'; -%>
      <%= selectorField.name %>: <%= zodType %>,
<% } -%>
    }),
<% } else { -%>
<% const selectorField = connectMeta.selector.fields[0]; const sf = targetModel.fields.find(f => f.name === selectorField.name); const zodType = sf ? getFieldZodType(sf) : 'z.string()'; -%>
    <%= selectorField.name %>: <%= zodType %>,
<% } -%>
  })<%= nr.isList ? ').min(1)' : '' %>.optional(),
}).refine(data => data.create || data.connect, {
  message: 'Either create or connect must be provided',
});
<% } else { -%>
export const <%= model.name %>_<%= h.toPascalCase(nr.name) %>Input = z.object({
  create: <%= nr.isList ? 'z.array(' : '' %>z.object({
<% for (const f of targetCreateFields) { -%>
<% const zt = getFieldZodType(f); const io = f.isOptional || f.hasDefault; -%>
    <%= f.name %>: <%= zt %><%= io ? '.optional()' : '' %>,
<% } -%>
  })<%= nr.isList ? ').min(1)' : '' %>,
});
<% } -%>
<% } -%>
<% } -%>

/**
 * Schema for creating a new <%= model.name %>.
 * Required fields from the Prisma schema are required here.
 * Optional fields (?) and fields with defaults are optional.
 * @bcm.readonly fields are excluded.
 */
export const Create<%= model.name %>Schema = z.object({
<% for (const field of createFields) { -%>
<% if (field.isRelation) continue; -%>
<%   /* Skip FK fields that have a corresponding @bcm.nested relation */ -%>
<%   const nestedForFk = nestedRelations.find(nr => nr.relationField && nr.relationField.split(', ').includes(field.name)); -%>
<%   if (nestedForFk) continue; -%>
<% const zodType = getFieldZodType(field); const isOpt = field.isOptional || field.hasDefault; -%>
  <%= field.name %>: <%= zodType %><%= isOpt ? '.optional()' : '' %>,<%= field.isUnique ? ' // Must be unique' : '' %>
<% } -%>
<% for (const nr of nestedRelations) { -%>
<%
  const nestedFk = nr.relationField ? nr.relationField.split(', ').map(f => f.trim()) : [];
  const nestedFkFields = nestedFk.map(name => model.fields.find(f => f.name === name)).filter(Boolean);
  const isNestedRequired = nestedFkFields.length > 0 && nestedFkFields.every(f => !f.isOptional && !f.hasDefault && !f.isServerDefault);
-%>
  <%= nr.name %>: <%= model.name %>_<%= h.toPascalCase(nr.name) %>Input<%= isNestedRequired ? '' : '.optional()' %>,
<% } -%>
});

/**
 * Schema for full update of a <%= model.name %>.
 * Same validation as Create -- all required fields must be present.
 */
export const Update<%= model.name %>Schema = Create<%= model.name %>Schema;

/**
 * Schema for partial update (PATCH) of a <%= model.name %>.
 * All fields are optional -- only provided fields are updated.
 */
export const Patch<%= model.name %>Schema = Create<%= model.name %>Schema.partial();

<% for (const relation of includeRelations) { -%>
<% const targetModel = allModels.find(m => m.name === relation.relationModel); -%>
<% if (targetModel) { -%>
<% const targetResponseFields = targetModel.fields.filter(f => !f.isRelation && !f.directives.includes('hidden') && !f.directives.includes('writeOnly')); -%>
export const <%= model.name %>_<%= h.toPascalCase(relation.name) %>RelationSchema = z.object({
<% for (const field of targetResponseFields) { -%>
<% const zodType = getFieldZodType(field, { coerceDate: true }); -%>
  <%= field.name %>: <%= zodType %><%= field.isOptional ? '.nullish()' : (field.hasDefault ? '.optional()' : '') %>,
<% } -%>
});

<% } -%>
<% } -%>

/**
 * Schema describing the API response shape for a <%= model.name %>.
 * @bcm.hidden and @bcm.writeOnly fields are excluded.
 */
export const <%= model.name %>ResponseSchema = z.object({
<% for (const field of responseFields) { -%>
<% if (field.isRelation) continue; -%>
<% const zodType = getFieldZodType(field, { coerceDate: true }); -%>
  <%= field.name %>: <%= zodType %><%= field.isOptional ? '.nullish()' : (field.hasDefault ? '.optional()' : '') %>,
<% } -%>
});

/**
 * Include-aware response schema for list/get endpoints when ?include=... is used.
 * Relations are optional because include is request-driven.
 */
export const <%= model.name %>WithIncludesResponseSchema = <%= model.name %>ResponseSchema.extend({
<% for (const relation of includeRelations) { -%>
<% const targetModel = allModels.find(m => m.name === relation.relationModel); -%>
<% if (targetModel) { -%>
<% const relationSchemaName = `${model.name}_${h.toPascalCase(relation.name)}RelationSchema`; -%>
<% const relationSchemaType = relation.isList ? `z.array(${relationSchemaName})` : `${relationSchemaName}${relation.isOptional ? '.nullable()' : ''}`; -%>
  <%= relation.name %>: <%= relationSchemaType %>.optional(),
<% } -%>
<% } -%>
});

export type Create<%= model.name %>Input = z.infer<typeof Create<%= model.name %>Schema>;
export type Update<%= model.name %>Input = z.infer<typeof Update<%= model.name %>Schema>;
export type Patch<%= model.name %>Input = z.infer<typeof Patch<%= model.name %>Schema>;
export type <%= model.name %>Response = z.infer<typeof <%= model.name %>ResponseSchema>;
export type <%= model.name %>WithIncludesResponse = z.infer<typeof <%= model.name %>WithIncludesResponseSchema>;
