<% if (itemSelector.fields.length === 1) { -%>
    return `<%= itemSelector.fields[0] %>=\"${key.<%= itemSelector.fields[0] %>}\"`;
<% } else { -%>
    return `<%= itemSelector.fields.map((f) => `${f}=\\\"\${key.${f}}\\\"`).join(', ') %>`;
<% } -%>
  }

<% } -%>
<% if (includeRelations.length > 0) { -%>
  toInclude(include?: Record<string, boolean>): Prisma.<%= model.name %>Include | undefined {
    if (!include) return undefined;
    const normalized: Prisma.<%= model.name %>Include = {};
<% for (const relation of includeRelations) { -%>
    if (include.<%= relation.name %>) normalized.<%= relation.name %> = true;
<% } -%>
    return Object.keys(normalized).length > 0 ? normalized : undefined;
  }

<% } -%>
<% if (cursorConfig) { -%>
  async findManyCursor(
    cursor: <%= cursorFieldMeta?.tsType ?? 'string' %> | null,
    pageSize: number,
    direction: 'forward' | 'backward' = 'forward',
    options?: { where?: Record<string, unknown>; include?: Record<string, boolean> },
  ): Promise<{ data: <%= model.name %>[]; hasMore: boolean; nextCursor: string | null }> {
<% if (includeRelations.length > 0) { -%>
    const include = options?.include ? this.toInclude(options.include) : undefined;
<% } -%>
    const take = (direction === 'backward' ? -1 : 1) * (pageSize + 1);
    const findArgs: Record<string, unknown> = {
      take,
      orderBy: { <%= cursorConfig.field %>: direction === 'backward' ? 'desc' : 'asc' },
<% if (isSoftDelete) { -%>
      where: { ...options?.where, deletedAt: null },
<% } else { -%>
      ...(options?.where ? { where: options.where } : {}),
<% } -%>
<% if (includeRelations.length > 0) { -%>
      ...(include ? { include } : {}),
<% } -%>
    };
    if (cursor) {
      findArgs.cursor = { <%= cursorConfig.field %>: cursor };
      findArgs.skip = 1;
    }
    const results = await prisma.<%= h.toCamelCase(model.name) %>.findMany(findArgs as any);
    const hasMore = results.length > pageSize;
    const data = hasMore ? results.slice(0, pageSize) : results;
    const nextCursor = data.length > 0 ? String((data[data.length - 1] as any).<%= cursorConfig.field %>) : null;
    return { data, hasMore, nextCursor };
  }

<% } -%>
  async findMany(options: QueryOptions): Promise<{ data: <%= model.name %>[]; total: number }> {
<% if (includeRelations.length > 0) { -%>
    const include = this.toInclude(options.include);
<% } -%>
    const [data, total] = await Promise.all([
      prisma.<%= h.toCamelCase(model.name) %>.findMany({
<% if (isSoftDelete) { %>
        where: { ...options.where, deletedAt: null },
<% } else { %>
        where: options.where,
<% } %>
        orderBy: options.orderBy,
        skip: options.skip,
        take: options.take,
<% if (includeRelations.length > 0) { -%>
        ...(include ? { include } : {}),
<% } -%>
      }),
<% if (isSoftDelete) { %>
      prisma.<%= h.toCamelCase(model.name) %>.count({ where: { ...options.where, deletedAt: null } }),
<% } else { %>
      prisma.<%= h.toCamelCase(model.name) %>.count({ where: options.where }),
<% } %>
    ]);
    return { data, total };
  }

