  async updateScoped(key: <%= model.name %>Key, tenantId: string, data: Record<string, unknown>): Promise<<%= model.name %>> {
    const where = this.scopedWhere(key, tenantId);
    const message = `<%= model.name %> with key "${this.keyDescription(key)}" not found for tenant "${tenantId}".`;
    try {
<% if (isSoftDelete) { -%>
      const updated = await prisma.<%= h.toCamelCase(model.name) %>.updateMany({ where, data: data as any });
      if (updated.count === 0) {
