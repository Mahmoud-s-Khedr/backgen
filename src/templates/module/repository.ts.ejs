          detail: message,
        });
      }
      const record = await prisma.<%= h.toCamelCase(model.name) %>.findFirst({ where });
      if (!record) {
        throw new ProblemDetail({
          type: 'not-found', title: 'Not Found', status: 404,
          detail: message,
        });
      }
      return record;
<% } else { -%>
      const record = await prisma.<%= h.toCamelCase(model.name) %>.findFirst({ where });
      if (!record) {
        throw new ProblemDetail({
          type: 'not-found', title: 'Not Found', status: 404,
          detail: message,
