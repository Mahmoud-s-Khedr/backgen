import type { QueryOptions } from '../../utils/query-builder.js';
<% if (model.isAuthModel && model.passwordField) { -%>
import bcrypt from 'bcryptjs';
<% } -%>
import type { <%= model.name %> } from '@prisma/client';
import type { Create<%= model.name %>Input, Patch<%= model.name %>Input } from './<%= h.toCamelCase(model.name) %>.dto.js';
import { <%= model.name %>Repository<% if (itemSelector) { %>, type <%= model.name %>Key<% } %> } from './<%= h.toCamelCase(model.name) %>.repository.js';
<% if (cacheConfig) { -%>
import { redis } from '../../config/redis.js';

const CACHE_TTL = <%= cacheConfig.ttl %>;
const CACHE_PREFIX = '<%= h.toCamelCase(model.name) %>';
const CACHE_VERSION_KEY = `${CACHE_PREFIX}:v`;
<% } -%>
<% if (isEvent) { -%>
import { eventBus } from '../../utils/event-bus.js';
<% } -%>
<% if (isAudit) { -%>
import { writeAuditLog } from '../../utils/audit.js';
<% } -%>

/**
 * <%= model.name %> Service
 * Business logic layer — delegates all database access to <%= model.name %>Repository.
 */
export class <%= model.name %>Service {
  private repo = new <%= model.name %>Repository();
<% if (cacheConfig) { -%>

  private async getCacheVersion(): Promise<string> {
    const version = await redis.get(CACHE_VERSION_KEY);
    if (version) {
      return version;
    }
    await redis.set(CACHE_VERSION_KEY, '1');
    return '1';
  }

  private async bumpCacheVersion(): Promise<void> {
    await redis.incr(CACHE_VERSION_KEY);
  }
<% } -%>

<% if (cursorConfig) { -%>
  /**
   * Find many <%= h.pluralize(h.toCamelCase(model.name)) %> with cursor-based pagination.
   */
<% if (multitenancyConfig) { -%>
  async findManyCursor(
    cursor: <%= cursorFieldMeta?.tsType ?? 'string' %> | null,
    pageSize: number,
    direction: 'forward' | 'backward' = 'forward',
    tenantId: string,
    options?: { where?: Record<string, unknown>; include?: Record<string, boolean> },
  ): Promise<{ data: <%= model.name %>[]; hasMore: boolean; nextCursor: string | null }> {
    const where = { ...options?.where, <%= multitenancyConfig.field %>: tenantId };
    return this.repo.findManyCursor(cursor, pageSize, direction, { ...options, where });
  }
<% } else { -%>
  async findManyCursor(
    cursor: <%= cursorFieldMeta?.tsType ?? 'string' %> | null,
    pageSize: number,
    direction: 'forward' | 'backward' = 'forward',
    options?: { where?: Record<string, unknown>; include?: Record<string, boolean> },
  ): Promise<{ data: <%= model.name %>[]; hasMore: boolean; nextCursor: string | null }> {
    return this.repo.findManyCursor(cursor, pageSize, direction, options);
  }
<% } -%>

<% } -%>
  /**
   * Find many <%= h.pluralize(h.toCamelCase(model.name)) %> with pagination, sorting, and filtering.
   */
<% if (multitenancyConfig) { -%>
  async findMany(options: QueryOptions, tenantId: string): Promise<{ data: <%= model.name %>[]; total: number }> {
    const scopedOptions = { ...options, where: { ...options.where, <%= multitenancyConfig.field %>: tenantId } };
<% if (cacheConfig) { -%>
    const version = await this.getCacheVersion();
    const cacheKey = `${CACHE_PREFIX}:v:${version}:list:${JSON.stringify(scopedOptions)}`;
    const cached = await redis.get(cacheKey);
    if (cached) return JSON.parse(cached) as { data: <%= model.name %>[]; total: number };
    const result = await this.repo.findMany(scopedOptions);
    await redis.set(cacheKey, JSON.stringify(result), { EX: CACHE_TTL });
    return result;
<% } else { -%>
    return this.repo.findMany(scopedOptions);
<% } -%>
  }
<% } else { -%>
  async findMany(options: QueryOptions): Promise<{ data: <%= model.name %>[]; total: number }> {
<% if (cacheConfig) { -%>
    const version = await this.getCacheVersion();
    const cacheKey = `${CACHE_PREFIX}:v:${version}:list:${JSON.stringify(options)}`;
    const cached = await redis.get(cacheKey);
    if (cached) return JSON.parse(cached) as { data: <%= model.name %>[]; total: number };
    const result = await this.repo.findMany(options);
    await redis.set(cacheKey, JSON.stringify(result), { EX: CACHE_TTL });
    return result;
<% } else { -%>
    return this.repo.findMany(options);
<% } -%>
  }
<% } -%>

<% if (itemSelector) { -%>
  /**
   * Find a single <%= h.toCamelCase(model.name) %> by key.
   */
<% if (multitenancyConfig) { -%>
  async findOne(key: <%= model.name %>Key, tenantId: string, include?: Record<string, boolean>): Promise<<%= model.name %> | null> {
    return this.repo.findOneScoped(key, tenantId, include);
<% } else { -%>
  async findOne(key: <%= model.name %>Key, include?: Record<string, boolean>): Promise<<%= model.name %> | null> {
<% if (cacheConfig) { -%>
    const version = await this.getCacheVersion();
    const cacheKey = `${CACHE_PREFIX}:v:${version}:item:${JSON.stringify(key)}:${JSON.stringify(include ?? {})}`;
    const cached = await redis.get(cacheKey);
    if (cached) return JSON.parse(cached) as <%= model.name %>;
    const result = await this.repo.findOne(key, include);
    if (result) await redis.set(cacheKey, JSON.stringify(result), { EX: CACHE_TTL });
    return result;
<% } else { -%>
    return this.repo.findOne(key, include);
<% } -%>
<% } -%>
  }
<% } -%>

  /**
   * Create a new <%= h.toCamelCase(model.name) %>.
   */
<% if (isAudit) { -%>
  async create(data: Create<%= model.name %>Input, changedBy?: string): Promise<<%= model.name %>> {
<% } else { -%>
  async create(data: Create<%= model.name %>Input): Promise<<%= model.name %>> {
<% } -%>
<% if (model.isAuthModel && model.passwordField) { -%>
    const createData: Record<string, unknown> = { ...data };
    if (typeof createData.<%= model.passwordField %> === 'string') {
      createData.<%= model.passwordField %> = await bcrypt.hash(createData.<%= model.passwordField %> as string, 12);
    }
    const result = await this.repo.create(createData);
<% } else { -%>
    const result = await this.repo.create(data as Record<string, unknown>);
<% } -%>
<% if (cacheConfig) { -%>
    await this.bumpCacheVersion();
<% } -%>
<% if (isEvent) { -%>
    eventBus.emit('<%= model.name %>', 'created', result);
<% } -%>
<% if (isAudit) { -%>
    await writeAuditLog({ model: '<%= model.name %>', recordId: String((result as any).id ?? ''), action: 'CREATE', changedBy, after: result as any });
<% } -%>
    return result;
  }

<% if (itemSelector) { -%>
  /**
   * Update a <%= h.toCamelCase(model.name) %> by key.
   */
<% if (isAudit) { -%>
  async update(key: <%= model.name %>Key, data: Create<%= model.name %>Input | Patch<%= model.name %>Input, changedBy?: string): Promise<<%= model.name %>> {
<% } else { -%>
  async update(key: <%= model.name %>Key, data: Create<%= model.name %>Input | Patch<%= model.name %>Input): Promise<<%= model.name %>> {
<% } -%>
<% if (isAudit) { -%>
    const before = await this.repo.findOne(key);
<% } -%>
<% if (model.isAuthModel && model.passwordField) { -%>
    const updateData: Record<string, unknown> = { ...data };
    if (typeof updateData.<%= model.passwordField %> === 'string') {
      updateData.<%= model.passwordField %> = await bcrypt.hash(updateData.<%= model.passwordField %> as string, 12);
    }
    const result = await this.repo.update(key, updateData);
<% } else { -%>
    const result = await this.repo.update(key, data as Record<string, unknown>);
<% } -%>
<% if (cacheConfig) { -%>
    await this.bumpCacheVersion();
<% } -%>
<% if (isEvent) { -%>
    eventBus.emit('<%= model.name %>', 'updated', result);
<% } -%>
<% if (isAudit) { -%>
    await writeAuditLog({ model: '<%= model.name %>', recordId: String((result as any).id ?? ''), action: 'UPDATE', changedBy, before: before as any, after: result as any });
<% } -%>
    return result;
  }

  /**
   * Delete a <%= h.toCamelCase(model.name) %> by key.
   */
<% if (isAudit) { -%>
  async delete(key: <%= model.name %>Key, changedBy?: string): Promise<void> {
<% } else { -%>
  async delete(key: <%= model.name %>Key): Promise<void> {
<% } -%>
<% if (isAudit || isEvent || (hasUploads)) { -%>
    const record = await this.repo.findOne(key);
<% } -%>
<% if (hasUploads) { -%>
    if (record) {
      const { unlink } = await import('fs/promises');
<%   for (const uf of uploadFields) { -%>
      if ((record as any).<%= uf.name %>) {
        await unlink(String((record as any).<%= uf.name %>)).catch(() => {});
      }
<%   } -%>
    }
<% } -%>
    await this.repo.delete(key);
<% if (cacheConfig) { -%>
    await this.bumpCacheVersion();
<% } -%>
<% if (isEvent) { -%>
    eventBus.emit('<%= model.name %>', 'deleted', record ?? key);
<% } -%>
<% if (isAudit) { -%>
    await writeAuditLog({ model: '<%= model.name %>', recordId: String((key as any).id ?? JSON.stringify(key)), action: 'DELETE', changedBy, before: record as any });
<% } -%>
  }
<% } -%>
}
