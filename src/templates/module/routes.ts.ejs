import { Router } from 'express';
import { <%= model.name %>Controller } from './<%= h.toCamelCase(model.name) %>.controller.js';
import { Create<%= model.name %>Schema, Update<%= model.name %>Schema, Patch<%= model.name %>Schema } from './<%= h.toCamelCase(model.name) %>.dto.js';
import { validate } from '../../middlewares/validation.middleware.js';
<% if (isProtected) { %>
import { authenticate<%= authRoles.length > 0 ? ', authorize' : '' %> } from '../../middlewares/auth.middleware.js';
<% } %>
const router = Router();
const controller = new <%= model.name %>Controller();
<% const roleGuard = authRoles.length > 0 ? `, authorize(${authRoles.map(r => `'${r}'`).join(', ')})` : ''; %>

router.get('/', (req, res, next) => controller.list(req, res, next));
router.get('/:id', (req, res, next) => controller.getById(req, res, next));
<% if (isProtected) { %>
router.post('/', authenticate<%- roleGuard %>, validate(Create<%= model.name %>Schema), (req, res, next) => controller.create(req, res, next));
router.put('/:id', authenticate<%- roleGuard %>, validate(Update<%= model.name %>Schema), (req, res, next) => controller.update(req, res, next));
router.patch('/:id', authenticate<%- roleGuard %>, validate(Patch<%= model.name %>Schema), (req, res, next) => controller.patch(req, res, next));
router.delete('/:id', authenticate<%- roleGuard %>, (req, res, next) => controller.remove(req, res, next));
<% } else { %>
router.post('/', validate(Create<%= model.name %>Schema), (req, res, next) => controller.create(req, res, next));
router.put('/:id', validate(Update<%= model.name %>Schema), (req, res, next) => controller.update(req, res, next));
router.patch('/:id', validate(Patch<%= model.name %>Schema), (req, res, next) => controller.patch(req, res, next));
router.delete('/:id', (req, res, next) => controller.remove(req, res, next));
<% } %>
export { router as <%= h.toCamelCase(model.name) %>Routes };
