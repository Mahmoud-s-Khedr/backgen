datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id String @id @default(cuid())
  posts Post[]
}

model Post {
  id String @id @default(cuid())
  /// @bcm.hidden
  authorId String
  /// @bcm.nested
  author User @relation(fields: [authorId], references: [id])
  title String
}
