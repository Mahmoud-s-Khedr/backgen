// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ListingType {
  sell
  buy
  swap
}

enum ItemCondition {
  new
  used
  refurbished
}

enum ListingStatus {
  active
  sold
  archived
  pending
}

enum AttributeDataType {
  text
  number
  boolean
  select
}

enum OfferType {
  cash
  swap
  mixed
}

enum OfferStatus {
  pending
  accepted
  rejected
  cancelled
}

enum ReportStatus {
  open
  investigating
  resolved
  rejected
}

enum Currency {
  EGP
  USD
  EUR
}

// -------------------------
// Users
// -------------------------

// NOTE: @bcm.protected is intentionally omitted here.
// POST /api/users doubles as the public registration endpoint.
// After generation, add auth middleware only to PUT/PATCH/DELETE
// routes in user.routes.ts, or protect the model and expose a
// separate public /api/auth/register route manually.
/// @bcm.authModel
model User {
  id String @id @default(cuid())
  /// @bcm.identifier
  email    String  @unique
  /// @bcm.searchable
  username String  @unique
  phone    String? @unique
  /// @bcm.searchable
  fullName  String?
  avatarUrl String?
  /// @bcm.password
  passwordHash String

  // System-managed fields — excluded from all API inputs
  /// @bcm.readonly
  isVerified Boolean    @default(false)
  /// @bcm.readonly
  status     UserStatus @default(active)
  // Prevents self-promotion; only changeable by admins post-generation
  /// @bcm.readonly
  role       Role       @default(USER)
  /// @bcm.readonly
  createdAt  DateTime   @default(now())
  /// @bcm.readonly
  updatedAt  DateTime   @updatedAt

  // Relations
  listings                 Listing[]
  favorites                Favorite[]
  sentMessages             Message[]               @relation("MessageSender")
  conversationParticipants ConversationParticipant[]
  offersMade               Offer[]                 @relation("OfferFromUser")
  offersReceived           Offer[]                 @relation("OfferToUser")
  reviewsWritten           Review[]                @relation("ReviewReviewer")
  reviewsReceived          Review[]                @relation("ReviewReviewedUser")
  reports                  Report[]
  notifications            Notification[]

  @@index([username])
  @@index([phone])
}

// -------------------------
// Locations
// -------------------------

// Admin-managed location catalog; mutations locked to ADMIN role
/// @bcm.auth(roles: [ADMIN])
model Location {
  id String @id @default(cuid())

  country String
  state   String?
  city    String?
  area    String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  /// @bcm.readonly
  createdAt DateTime @default(now())
  /// @bcm.readonly
  updatedAt DateTime @updatedAt

  listings Listing[]

  @@index([country, state, city, area])
}

// -------------------------
// Categories (hierarchical)
// -------------------------

// Admin-managed taxonomy; mutations locked to ADMIN role
/// @bcm.auth(roles: [ADMIN])
model Category {
  id String @id @default(cuid())

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  /// @bcm.searchable
  name      String
  /// @bcm.searchable
  slug      String   @unique
  iconUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  /// @bcm.readonly
  createdAt DateTime @default(now())
  /// @bcm.readonly
  updatedAt DateTime @updatedAt

  listings   Listing[]
  attributes CategoryAttribute[]

  @@index([parentId])
  @@index([isActive, sortOrder])
}

// -------------------------
// Listings
// -------------------------

// Mutations require a valid JWT; soft-deleted instead of hard-removed.
// IMPORTANT: @bcm.softDelete requires the deletedAt field below.
//
// NOTE on ownership: bcm cannot auto-populate userId from the JWT.
// After generation, update listing.controller.ts to inject
// req.user.id into the create payload and validate it on updates.
/// @bcm.protected
/// @bcm.softDelete
model Listing {
  id String @id @default(cuid())

  // userId is excluded from DTO; API consumers pass the user
  // relation via connect. Post-generation: set from req.user.id.
  userId String
  /// @bcm.nested
  user   User   @relation(fields: [userId], references: [id])

  categoryId String
  /// @bcm.nested
  category   Category @relation(fields: [categoryId], references: [id])

  locationId String?
  /// @bcm.nested
  location   Location? @relation(fields: [locationId], references: [id])

  /// @bcm.searchable
  title       String
  /// @bcm.searchable
  description String?

  price    Decimal?  @db.Decimal(12, 2)
  currency Currency  @default(EGP)

  listingType ListingType
  condition   ItemCondition?

  status     ListingStatus @default(active)
  // Featured flag set by admins only; post-generation add ADMIN guard
  // to this field in the service or restrict via a separate endpoint.
  /// @bcm.readonly
  isFeatured Boolean       @default(false)
  /// @bcm.readonly
  viewsCount Int           @default(0)
  /// @bcm.readonly
  createdAt  DateTime      @default(now())
  /// @bcm.readonly
  updatedAt  DateTime      @updatedAt
  // Required by @bcm.softDelete
  deletedAt  DateTime?

  // Relations
  images          ListingImage[]
  attributeValues ListingAttributeValue[]
  favorites       Favorite[]
  conversations   Conversation[]
  offers          Offer[]
  offerSwapItems  OfferSwapItem[]
  reviews         Review[]
  reports         Report[]

  @@index([categoryId])
  @@index([userId])
  @@index([locationId])
  @@index([status])
  @@index([isFeatured])
  @@index([listingType])
}

// -------------------------
// Listing Images
// -------------------------

/// @bcm.protected
model ListingImage {
  id String @id @default(cuid())

  listingId String
  /// @bcm.nested
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  imageUrl  String
  sortOrder Int      @default(0)
  /// @bcm.readonly
  createdAt DateTime @default(now())

  @@index([listingId, sortOrder])
}

// -------------------------
// Dynamic Attributes (per category)
// -------------------------

/// @bcm.auth(roles: [ADMIN])
model CategoryAttribute {
  id String @id @default(cuid())

  categoryId String
  /// @bcm.nested
  category   Category @relation(fields: [categoryId], references: [id])

  /// @bcm.searchable
  name       String
  dataType   AttributeDataType
  isRequired Boolean           @default(false)
  sortOrder  Int               @default(0)
  /// @bcm.readonly
  createdAt  DateTime          @default(now())
  /// @bcm.readonly
  updatedAt  DateTime          @updatedAt

  values ListingAttributeValue[]

  @@index([categoryId, sortOrder])
}

/// @bcm.protected
model ListingAttributeValue {
  id String @id @default(cuid())

  listingId String
  /// @bcm.nested
  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attributeId String
  /// @bcm.nested
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id])

  // One of these is populated depending on attribute.dataType
  valueText    String?
  valueNumber  Decimal? @db.Decimal(18, 4)
  valueBoolean Boolean?
  valueOption  String?

  @@index([listingId])
  @@index([attributeId])
  @@unique([listingId, attributeId])
}

// -------------------------
// Favorites (wishlist)
// -------------------------

// BCM CHANGE: Added surrogate `id` field and replaced @@id([userId, listingId])
// with @@unique. bcm does not support composite primary keys — the generator
// expects a single @id field per model. The @@unique constraint preserves the
// original uniqueness guarantee.
/// @bcm.protected
model Favorite {
  id        String @id @default(cuid())
  userId    String
  listingId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// @bcm.readonly
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

// -------------------------
// Messaging / Chat
// -------------------------

/// @bcm.protected
model Conversation {
  id String @id @default(cuid())

  listingId String?
  /// @bcm.nested
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  /// @bcm.readonly
  createdAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@index([listingId])
}

// BCM CHANGE: Added surrogate `id` field and replaced @@id([conversationId, userId])
// with @@unique. Same reason as Favorite — bcm requires a single @id field.
/// @bcm.protected
model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  /// @bcm.nested
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// @bcm.nested
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// @bcm.readonly
  createdAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

/// @bcm.protected
model Message {
  id String @id @default(cuid())

  conversationId String
  /// @bcm.nested
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  /// @bcm.nested
  sender   User @relation("MessageSender", fields: [senderId], references: [id])

  /// @bcm.searchable
  messageText String?
  isRead      Boolean  @default(false)
  /// @bcm.readonly
  createdAt   DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// -------------------------
// Offers / Swaps
// -------------------------

/// @bcm.protected
model Offer {
  id String @id @default(cuid())

  listingId String
  /// @bcm.nested
  listing   Listing @relation(fields: [listingId], references: [id])

  fromUserId String
  /// @bcm.nested
  fromUser   User @relation("OfferFromUser", fields: [fromUserId], references: [id])

  toUserId String
  /// @bcm.nested
  toUser   User @relation("OfferToUser", fields: [toUserId], references: [id])

  offeredPrice Decimal?  @db.Decimal(12, 2)
  offerType    OfferType

  // Status transitions (pending → accepted/rejected/cancelled) are
  // valid PATCH operations. Enforce state machine logic post-generation.
  status    OfferStatus @default(pending)
  message   String?
  /// @bcm.readonly
  createdAt DateTime    @default(now())
  /// @bcm.readonly
  updatedAt DateTime    @updatedAt

  swapItems OfferSwapItem[]

  @@index([listingId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

/// @bcm.protected
model OfferSwapItem {
  id String @id @default(cuid())

  offerId String
  /// @bcm.nested
  offer   Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  listingId String
  /// @bcm.nested
  listing   Listing @relation(fields: [listingId], references: [id])

  @@index([offerId])
  @@index([listingId])
}

// -------------------------
// Reviews
// -------------------------

/// @bcm.protected
model Review {
  id String @id @default(cuid())

  reviewerId String
  /// @bcm.nested
  reviewer   User @relation("ReviewReviewer", fields: [reviewerId], references: [id])

  reviewedUserId String
  /// @bcm.nested
  reviewedUser   User @relation("ReviewReviewedUser", fields: [reviewedUserId], references: [id])

  listingId String?
  /// @bcm.nested
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  rating  Int
  comment String?
  /// @bcm.readonly
  createdAt DateTime @default(now())

  @@index([reviewerId])
  @@index([reviewedUserId])
  @@index([listingId])
  @@unique([reviewerId, reviewedUserId, listingId])
}

// -------------------------
// Reporting & Moderation
// -------------------------

// Users can file reports (POST is auth-only via @bcm.protected).
// Status transitions are admin work — mark status readonly so the
// field can't be spoofed by the reporter; manage it via a separate
// admin endpoint or PATCH guard added post-generation.
/// @bcm.protected
model Report {
  id String @id @default(cuid())

  reporterId String?
  reporter   User? @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  listingId String?
  /// @bcm.nested
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  reason      String
  description String?
  // Managed by admins post-generation; not writable via public PATCH
  /// @bcm.readonly
  status    ReportStatus @default(open)
  /// @bcm.readonly
  createdAt DateTime     @default(now())

  @@index([reporterId])
  @@index([listingId])
  @@index([status])
}

// -------------------------
// Notifications
// -------------------------

// Notifications are system-generated. Users can only mark them read (isRead).
// All other fields are readonly to prevent tampering.
/// @bcm.protected
model Notification {
  id String @id @default(cuid())

  userId String
  /// @bcm.nested
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // System-set; not writable via API
  /// @bcm.readonly
  // Default keeps it system-managed while remaining valid for generated create flows.
  type        String @default("system")
  /// @bcm.readonly
  referenceId String?
  // Users PATCH this to true — intentionally left writable
  isRead      Boolean  @default(false)
  /// @bcm.readonly
  createdAt   DateTime @default(now())

  @@index([userId, isRead, createdAt])
}
