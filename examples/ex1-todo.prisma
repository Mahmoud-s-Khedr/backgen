// Example 1: Simple Todo List (SQLite)
// Complexity: Single model, basic field types
// Demonstrates: @bcm.readonly, @bcm.transform, SQLite provider (no Docker DB needed)

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Todo {
  id          String   @id @default(uuid())
  /// @bcm.transform(trim: true)
  title       String
  description String?
  completed   Boolean  @default(false)
  /// @bcm.readonly
  createdAt   DateTime @default(now())
  /// @bcm.readonly
  updatedAt   DateTime @updatedAt

  @@index([completed, createdAt])
}
